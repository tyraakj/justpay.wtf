# Supabase (Frontend)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Web3 Infrastructure (Client-side routing)
NEXT_PUBLIC_0X_API_KEY=your_0x_api_key

# Web3 Infrastructure (Server-side RPCs - Keep private)
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=your_api_key
ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/your_api_key

# Developer API Auth
MERCHANT_API_KEY=your_merchant_api_secret

# -------------------------------------------------------------
# SUPABASE SECRETS 
# (Set these in Supabase Edge Functions dashboard, not here)
# -------------------------------------------------------------
# SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# RESEND_API_KEY=your_resend_api_key
